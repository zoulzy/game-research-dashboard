{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": false,
  "headers": [
    {
      "source": "/game-scout-daily.json",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/game-research-dashboard.html"
    }
  ]
}
